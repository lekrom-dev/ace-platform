{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ace/engine-sdk": ["./packages/engine-sdk/src"],
      "@ace/engine-sdk/*": ["./packages/engine-sdk/src/*"],
      "@ace/ui": ["./packages/ui/src"],
      "@ace/ui/*": ["./packages/ui/src/*"],
      "@ace/db": ["./packages/db/src"],
      "@ace/db/*": ["./packages/db/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
